# hidden dimension scaling experiment for density ratio estimation

# directory configuration
data_dir: experiments/dre_hidden_dim_scaling/data
raw_results_dir: experiments/dre_hidden_dim_scaling/raw_results
processed_results_dir: experiments/dre_hidden_dim_scaling/processed_results
figures_dir: experiments/dre_hidden_dim_scaling/figures

# data generation
data_dim: 3
kl_divergence: 5.4
num_instances: 20
nsamples_train: 8100
nsamples_test: 1024

# hidden dimension sweep - main experimental variable
hidden_dims: [16, 32, 64, 128, 256]

# model hyperparameters
num_waypoints: 15
num_layers: 4
num_epochs: 100

# tsm-specific hyperparameters
tsm_n_epochs: 1000
tsm_batch_size: 512
tsm_lr: 0.001

# learning rate defaults per method
lr_defaults:
  TriangularMDRE: 0.05
  TriangularTDRE: 0.005
  MultiHeadTriangularTDRE: 0.005
  TSM: 0.001

# learning rate multipliers for sweep
lr_multipliers: [0.333, 1.0, 3.0, 9.0]

# algorithms to compare
algorithms:
  - TriangularMDRE
  - TriangularTDRE
  - MultiHeadTriangularTDRE
  - TSM

# compute configuration
device: cuda
seed: 1729
